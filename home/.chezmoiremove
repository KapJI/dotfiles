# Stale vim-plug install + plugin clones from the old vimscript nvim config.
# Plugged directory was hardcoded to ~/.vim/plugged in plug#begin() on every OS.
.vim/plugged
{{ if eq .osid "windows" -}}
AppData/Local/nvim-data/site/autoload/plug.vim
{{- else -}}
.local/share/nvim/site/autoload/plug.vim
{{- end }}

# Old vimscript nvim config files. The active config is now init.lua + lua/;
# leftover *.vim files trigger E5422 ("Conflicting configs: init.lua / init.vim").
{{ $nvim_dir := ternary "AppData/Local/nvim" ".config/nvim" (eq .osid "windows") -}}
{{ $nvim_dir }}/init.vim
{{ $nvim_dir }}/general.vim
{{ $nvim_dir }}/keymaps.vim
{{ $nvim_dir }}/plugins.vim
{{ $nvim_dir }}/terminal.vim
{{ $nvim_dir }}/theme.vim
{{ $nvim_dir }}/plugins/fern.vim
{{ $nvim_dir }}/plugins/fzf.vim
{{ $nvim_dir }}/plugins/lightline.vim
{{ $nvim_dir }}/plugins/signify.vim

# Removed Lua plugin specs. chezmoi leaves a target file in place when
# its source file is deleted, so an orphaned spec keeps getting loaded
# by lazy.nvim until removed here.
#   - oil.lua: oil.nvim replaced by yazi.nvim.
#   - vim-be-good.lua: motion-practice game; removed.
{{ $nvim_dir }}/lua/plugins/oil.lua
{{ $nvim_dir }}/lua/plugins/vim-be-good.lua

# Dead nvm loader: nvm isn't installed anywhere (node comes via nix /
# ~/.npm prefix), and eager nvm.sh sourcing is a notorious startup cost
# if it ever did appear.
.config/zsh/config.d/plugins/nvm.zsh

# vi-mode plugin config; source file was deleted in b0352b9 but the
# orphaned target lingered.
.config/zsh/config.d/plugins/vi_mode.zsh
