{{- /*
  Render a single ssh-agent-loaded public key whose comment ends with .name.
  Fails loudly (halting `chezmoi apply`) when:
    - ssh-add -L returns no keys (agent unreachable, empty, or stale socket)
    - no loaded key matches the requested name suffix
  The previous version silently rendered empty in either case, which once
  caused chezmoi to write empty pubkey files on a host where the tmux
  session's SSH_AUTH_SOCK pointed at a dead socket.
*/ -}}
{{- $name := .name -}}
{{- $output := output "ssh-add" "-L" | trim -}}
{{- if eq $output "" -}}
{{-   fail (printf "ssh-add -L returned no keys; cannot render pubkey %q. Ensure the SSH agent is running, SSH_AUTH_SOCK is reachable, and the agent has the needed key loaded." $name) -}}
{{- end -}}
{{- $found := "" -}}
{{- range $output | splitList "\n" -}}
{{-   $line := trimSuffix "\r" . -}}
{{-   if hasSuffix $name $line -}}
{{-     $found = $line -}}
{{-   end -}}
{{- end -}}
{{- if eq $found "" -}}
{{-   fail (printf "no key with comment suffix %q found in ssh-agent. Loaded keys:\n%s" $name $output) -}}
{{- end -}}
{{ $found }}
