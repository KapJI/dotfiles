{{ if and (eq .chezmoi.os "linux") .is_desktop -}}
#!/usr/bin/env bash
set -euo pipefail

DESKTOP_FILE="$HOME/.local/share/applications/chatgpt.desktop"
mkdir -p "$(dirname "$DESKTOP_FILE")"

cat > "$DESKTOP_FILE" <<'EOF'
[Desktop Entry]
Version=1.0
Type=Application
Name=ChatGPT
Comment=ChatGPT web app
Exec=google-chrome --app=https://chatgpt.com --class=ChatGPT --name=ChatGPT
Icon=google-chrome
Terminal=false
Categories=Network;WebBrowser;
StartupWMClass=ChatGPT
EOF

if command -v update-desktop-database &>/dev/null; then
    update-desktop-database "$HOME/.local/share/applications" >/dev/null 2>&1 || true
fi
{{ end -}}
