{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
set -euo pipefail

# Run weekly. Current week: {{ div now.YearDay 7 }}, {{ now.Year }}
#
# Astral's installer is idempotent and always pulls the latest release;
# re-running it weekly upgrades uv in place. Install to /usr/local/bin so uv
# is on PATH for subsequent chezmoi scripts (notably
# unix/before_15-install-uv-tools.sh) without needing any login-shell sourcing.
curl -LsSf https://astral.sh/uv/install.sh \
    | sudo env UV_INSTALL_DIR=/usr/local/bin UV_NO_MODIFY_PATH=1 sh
{{ end -}}
