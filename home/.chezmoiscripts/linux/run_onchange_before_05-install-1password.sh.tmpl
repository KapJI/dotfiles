{{ if and (has .osid (list "linux-debian" "linux-ubuntu")) .is_desktop -}}
#!/usr/bin/env bash
set -euo pipefail

KEYRING=/usr/share/keyrings/1password-archive-keyring.gpg
LIST=/etc/apt/sources.list.d/1password.list
SOURCES=/etc/apt/sources.list.d/1password.sources
DEBSIG_POLICY_DIR=/etc/debsig/policies/AC2D62742012EA22
DEBSIG_KEYRING_DIR=/usr/share/debsig/keyrings/AC2D62742012EA22

# The official 1Password .deb installer drops a `1password.sources` file. If
# it's already present, defer to it - adding our own `1password.list` collides
# (apt warns about duplicate targets) and the GUI/CLI are already installable.
if [ -f "$SOURCES" ]; then
    if [ -f "$LIST" ]; then
        sudo rm -f "$LIST"
    fi
    exit 0
fi

if [ -f "$KEYRING" ] && [ -f "$LIST" ]; then
    exit 0
fi

curl -sS https://downloads.1password.com/linux/keys/1password.asc \
    | sudo gpg --dearmor --yes --output "$KEYRING"

echo 'deb [arch=amd64 signed-by=/usr/share/keyrings/1password-archive-keyring.gpg] https://downloads.1password.com/linux/debian/amd64 stable main' \
    | sudo tee "$LIST" >/dev/null

sudo mkdir -p "$DEBSIG_POLICY_DIR" "$DEBSIG_KEYRING_DIR"
curl -sS https://downloads.1password.com/linux/debian/debsig/1password.pol \
    | sudo tee "$DEBSIG_POLICY_DIR/1password.pol" >/dev/null
curl -sS https://downloads.1password.com/linux/keys/1password.asc \
    | sudo gpg --dearmor --yes --output "$DEBSIG_KEYRING_DIR/debsig.gpg"

# apt-get update is deferred to before_12 - running it here would abort the
# script chain (set -e) on any unrelated repo error.
{{ end -}}
