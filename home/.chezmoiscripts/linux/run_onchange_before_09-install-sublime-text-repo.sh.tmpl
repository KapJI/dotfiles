{{ if and (has .osid (list "linux-debian" "linux-ubuntu")) .is_desktop -}}
#!/usr/bin/env bash
set -euo pipefail

KEYRING=/etc/apt/keyrings/sublimehq-archive-keyring.gpg
SOURCES=/etc/apt/sources.list.d/sublime-text.sources

if [ -f "$KEYRING" ] && [ -f "$SOURCES" ]; then
    exit 0
fi

sudo mkdir -p /etc/apt/keyrings
curl -fsSL https://download.sublimetext.com/sublimehq-pub.gpg \
    | sudo gpg --dearmor --yes --output "$KEYRING"

sudo tee "$SOURCES" >/dev/null <<EOF
Types: deb
URIs: https://download.sublimetext.com/
Suites: apt/stable/
Signed-By: $KEYRING
EOF
{{ end -}}
