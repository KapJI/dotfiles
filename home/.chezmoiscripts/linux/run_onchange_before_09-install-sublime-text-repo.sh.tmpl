{{ if and (has .osid (list "linux-debian" "linux-ubuntu")) .is_desktop -}}
#!/usr/bin/env bash
set -euo pipefail

KEYRING=/usr/share/keyrings/sublimehq-archive-keyring.gpg
LIST=/etc/apt/sources.list.d/sublime-text.list

if [ -f "$KEYRING" ] && [ -f "$LIST" ]; then
    exit 0
fi

curl -fsSL https://download.sublimetext.com/sublimehq-pub.gpg \
    | sudo gpg --dearmor --yes --output "$KEYRING"

echo "deb [signed-by=$KEYRING] https://download.sublimetext.com/ apt/stable/" \
    | sudo tee "$LIST" >/dev/null

# sublime-text package itself is installed in before_12 via the deb-desktop key.
{{ end -}}
