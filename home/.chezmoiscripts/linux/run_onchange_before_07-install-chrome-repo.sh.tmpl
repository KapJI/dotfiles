{{ if and (has .osid (list "linux-debian" "linux-ubuntu")) .is_desktop -}}
#!/usr/bin/env bash
set -euo pipefail

KEYRING=/etc/apt/keyrings/google-chrome-archive-keyring.gpg
SOURCES=/etc/apt/sources.list.d/google-chrome.sources

# The official google-chrome-stable .deb post-install also writes a
# google-chrome.sources file at the same path - defer to it if present.
if [ -f "$SOURCES" ]; then
    exit 0
fi

sudo mkdir -p /etc/apt/keyrings
curl -fsSL https://dl.google.com/linux/linux_signing_key.pub \
    | sudo gpg --dearmor --yes --output "$KEYRING"

sudo tee "$SOURCES" >/dev/null <<EOF
Types: deb
URIs: https://dl.google.com/linux/chrome/deb/
Suites: stable
Components: main
Architectures: amd64
Signed-By: $KEYRING
EOF
{{ end -}}
