{{ if has .osid (list "linux-debian" "linux-ubuntu") -}}
#!/usr/bin/env bash
# host: {{ .chezmoi.hostname }}
set -euo pipefail

# Install / update the fastfetch-based motd panel. Layout:
#
#   <hostname figlet banner — full width, blue>
#   <small auto-detected distro logo>   <fastfetch info modules>
#
# - /etc/fastfetch/hostname-banner.txt  figlet of $(hostname), printed
#                                       by the wrapper as a top banner
# - /etc/fastfetch/motd.jsonc           fastfetch config (logo.type =
#                                       "small" auto-detects distro)
# - /etc/update-motd.d/50-sysinfo       wrapper that prints the banner
#                                       then exec's fastfetch
#
# The hostname comment above pins the script's content-hash to this host's
# hostname — chezmoi's run_onchange will re-run when hostname changes
# (rare, but cheap).
#
# Errors from fastfetch (missing binary, bad config) are intentionally NOT
# silenced. They surface on stderr and reach update-motd's journal output;
# login still proceeds because update-motd tolerates per-script failures.

sudo install -d -m 0755 /etc/fastfetch

# figlet generates the hostname banner with the standard font (6 lines,
# most readable for hostnames). -w 200 disables figlet's auto-wrap to
# keep long hostnames on a single banner row; modern terminals handle
# the resulting >80-col line via wrap or scroll. The script runs in
# the user's interactive PATH (so user-level nix profile is available);
# the rendered file is written under /etc with sudo.
figlet -w 200 "$(hostname)" | sudo tee /etc/fastfetch/hostname-banner.txt >/dev/null

sudo tee /etc/fastfetch/motd.jsonc >/dev/null <<'JSONC'
{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": { "type": "small" },
  "display": { "separator": "  " },
  "modules": [
    "title",
    "separator",
    { "type": "os",        "key": "OS         " },
    { "type": "kernel",    "key": "Kernel     " },
    { "type": "uptime",    "key": "Uptime     " },
    { "type": "loadavg",   "key": "Load       ", "compact": true },
    { "type": "memory",    "key": "Memory     ", "format": "{used} / {total} ({percentage})" },
    { "type": "swap",      "key": "Swap       ", "format": "{used} / {total} ({percentage})" },
    { "type": "disk",      "key": "Disk (/)   ", "folders": "/", "format": "{size-used} / {size-total} ({size-percentage})" },
    { "type": "localip",   "key": "IPv4       ", "showIpv4": true, "showIpv6": false, "format": "{ipv4} ({ifname})" },
    { "type": "users",     "key": "Users      " },
    { "type": "processes", "key": "Processes  " }
  ]
}
JSONC

sudo tee /etc/update-motd.d/50-sysinfo >/dev/null <<'SH'
#!/bin/sh
# Render the fastfetch-based system info panel.
# Layout: hostname banner on top (blue), then small distro logo + info
# columns from fastfetch below.
#
# Errors are NOT silenced — visible via `journalctl -t update-motd` or by
# running `run-parts /etc/update-motd.d/`. update-motd tolerates per-script
# failures, so a missing fastfetch or broken config doesn't block login.
#
# Why the path search: on Debian, pam_motd reads only the cached
# /run/motd.dynamic; the cache is rebuilt by run-parts running as root,
# so $HOME is /root and a user-level nix profile under /home/<user>/ is
# not on PATH. Iterate common locations so root-time rebuilds still find
# fastfetch wherever it actually lives.

# Top banner: hostname figlet, blue, full width.
if [ -f /etc/fastfetch/hostname-banner.txt ]; then
    printf '\033[1;34m'
    cat /etc/fastfetch/hostname-banner.txt
    printf '\033[0m'
fi

for ff in \
    /nix/var/nix/profiles/default/bin/fastfetch \
    "$HOME/.nix-profile/bin/fastfetch" \
    /home/*/.nix-profile/bin/fastfetch \
    /usr/local/bin/fastfetch \
    /usr/bin/fastfetch
do
    [ -x "$ff" ] && exec "$ff" --config /etc/fastfetch/motd.jsonc
done
echo "50-sysinfo: fastfetch not found in any expected path" >&2
exit 1
SH
sudo chmod +x /etc/update-motd.d/50-sysinfo

# Silence the static Debian "ABSOLUTELY NO WARRANTY..." banner from
# /etc/motd. pam_motd prints /etc/motd BEFORE the dynamic motd, so on
# stock Debian you see the warranty boilerplate above our fastfetch
# panel on every login. Truncate (don't remove) so the file still
# exists if something later expects it.
sudo truncate -s 0 /etc/motd

# Regenerate the cached motd so the new entry appears at next login without
# waiting for a reboot. Debian's vanilla pam_motd.so reads /run/motd.dynamic
# but does not auto-rebuild it (unlike Ubuntu's patched variant). Run-parts
# the directory once here; pam_motd will then serve the fresh content.
sudo sh -c 'run-parts --lsbsysinit /etc/update-motd.d/ > /run/motd.dynamic' || true
{{ end -}}
