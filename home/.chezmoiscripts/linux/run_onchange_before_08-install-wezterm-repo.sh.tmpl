{{ if and (has .osid (list "linux-debian" "linux-ubuntu")) .is_desktop -}}
#!/usr/bin/env bash
set -euo pipefail

KEYRING=/usr/share/keyrings/wezterm-fury.gpg
LIST=/etc/apt/sources.list.d/wezterm.list

if [ -f "$KEYRING" ] && [ -f "$LIST" ]; then
    exit 0
fi

curl -fsSL https://apt.fury.io/wez/gpg.key \
    | sudo gpg --yes --dearmor --output "$KEYRING"
sudo chmod 644 "$KEYRING"

echo 'deb [signed-by=/usr/share/keyrings/wezterm-fury.gpg] https://apt.fury.io/wez/ * *' \
    | sudo tee "$LIST" >/dev/null

# wezterm package itself is installed in before_12 via the deb-desktop key.
{{ end -}}
