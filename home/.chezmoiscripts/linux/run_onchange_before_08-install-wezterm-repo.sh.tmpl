{{ if and (has .osid (list "linux-debian" "linux-ubuntu")) .is_desktop -}}
#!/usr/bin/env bash
set -euo pipefail

KEYRING=/etc/apt/keyrings/wezterm-fury.gpg
SOURCES=/etc/apt/sources.list.d/wezterm.sources

if [ -f "$KEYRING" ] && [ -f "$SOURCES" ]; then
    exit 0
fi

sudo mkdir -p /etc/apt/keyrings
curl -fsSL https://apt.fury.io/wez/gpg.key \
    | sudo gpg --dearmor --yes --output "$KEYRING"
sudo chmod 644 "$KEYRING"

sudo tee "$SOURCES" >/dev/null <<EOF
Types: deb
URIs: https://apt.fury.io/wez/
Suites: *
Components: *
Signed-By: $KEYRING
EOF
{{ end -}}
