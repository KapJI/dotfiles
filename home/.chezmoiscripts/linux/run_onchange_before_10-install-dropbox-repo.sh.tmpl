{{ if and (has .osid (list "linux-debian" "linux-ubuntu")) .is_desktop -}}
#!/usr/bin/env bash
set -euo pipefail

KEYRING=/etc/apt/keyrings/dropbox-archive-keyring.gpg
SOURCES=/etc/apt/sources.list.d/dropbox.sources
CODENAME="{{ .chezmoi.osRelease.versionCodename }}"

if [ -f "$KEYRING" ] && [ -f "$SOURCES" ]; then
    exit 0
fi

sudo mkdir -p /etc/apt/keyrings
curl -fsSL https://linux.dropbox.com/fedora/rpm-public-key.asc \
    | sudo gpg --dearmor --yes --output "$KEYRING"

sudo tee "$SOURCES" >/dev/null <<EOF
Types: deb
URIs: http://linux.dropbox.com/ubuntu
Suites: ${CODENAME}
Components: main
Architectures: amd64
Signed-By: $KEYRING
EOF
{{ end -}}
