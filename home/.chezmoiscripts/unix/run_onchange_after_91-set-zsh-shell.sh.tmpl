#!/usr/bin/env bash


if [[ $SHELL == */zsh ]]; then
    echo "Shell is already set to zsh"
    exit 0
fi

YELLOW='\033[0;33m'
CYAN='\033[0;36m'
NC='\033[0m'

{{ if eq .osid "linux-centos" -}}
zsh_path="$(command -v zsh)"
printf "${YELLOW}Shell should be changed in 'i unix/shell'${NC}\n"
exit 1
{{ else if eq .osid "darwin" -}}
zsh_path="$(command -v zsh)"
current_shell="$(dscl . -read /Users/$USER UserShell | awk '{print $2}')"
if [ "$current_shell" != "$zsh_path" ]; then
    sudo dscl . -create "/Users/$USER" UserShell "$zsh_path"
fi
{{ else -}}
# Linux: prefer a system zsh listed in /etc/shells. chsh-ing to a nix
# profile path that isn't in /etc/shells can lock the user out of SSH
# (PAM/shell-validity check) — and even if chsh succeeds, removing apt
# zsh later would invalidate the login shell. System zsh stays as the
# login shell; nix zsh is still available interactively for non-login use.
zsh_path=""
for candidate in /usr/bin/zsh /bin/zsh; do
    if [ -x "$candidate" ] && grep -qxF "$candidate" /etc/shells; then
        zsh_path="$candidate"
        break
    fi
done
if [ -z "$zsh_path" ]; then
    printf "${YELLOW}No system zsh in /etc/shells found; not running chsh.${NC}\n"
    printf "${YELLOW}Install with: sudo apt install zsh${NC}\n"
    exit 0
fi

current_shell="$(readlink -f "$SHELL")"
new_shell="$(readlink -f "$zsh_path")"
if [ "$current_shell" != "$new_shell" ]; then
    chsh -s "$zsh_path"
fi
{{ end }}
