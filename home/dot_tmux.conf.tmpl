{{- if and (eq .chezmoi.os "linux") (not .is_desktop) -}}
##### Basics #####

# Mouse for resize, scroll, select panes
set -g mouse on

# Required for imgcat
set -g allow-passthrough on

# History buffer (default ~2000)
set -g history-limit 50000

# Use tmux-256color for proper terminfo support
set -g default-terminal "tmux-256color"

# Enable TrueColor support for vim
set -ga terminal-overrides ",*-256color*:RGB"

# Index windows/panes from 1
set -g base-index 1
setw -g pane-base-index 1

##### Window & session behaviour #####

# Renumber windows after closing
set -g renumber-windows on

# Per-pane window titles. Programs set OSC 2 → tmux updates each pane's
# `pane_title` independently. With `allow-rename off`, the OSC does NOT
# also rename the window directly. We then rename the window from the
# active pane's title via hooks fired on the relevant events:
#
#   pane-focus-in       — when a pane gains focus, take its title.
#   pane-title-changed  — when the ACTIVE pane's title changes, take
#                         it. Guarded on #{pane_active} so a title
#                         update in a background split doesn't
#                         clobber the window name.
#
# Falls back to #{pane_current_command} for panes whose program hasn't
# emitted a title yet.
#
# automatic-rename is left off because its internal re-evaluation is
# multi-second and doesn't fire on pane_title or focus changes — using
# it instead of these hooks produces a visible lag after `cd` and on
# split switches.
set -g allow-rename off
setw -g automatic-rename off

set-hook -g pane-focus-in {
  rename-window "#{?pane_title,#{pane_title},#{pane_current_command}}"
}
set-hook -g pane-title-changed {
  if-shell -F "#{pane_active}" {
    rename-window "#{?pane_title,#{pane_title},#{pane_current_command}}"
  }
}

# Set terminal title from active window
set -g set-titles on

# Compact outer-terminal title (wezterm tab name): a server glyph
# (nf-fa-server) + the short hostname. host_short strips the FQDN
# suffix (server.example.com → server). The glyph makes SSH'd tabs
# instantly scannable; window/pane detail stays in tmux's own status
# bar inside the pane rather than being repeated in the outer tab.
set -g set-titles-string ' #{host_short}'

# Match window size to current client (vs largest attached)
setw -g aggressive-resize on


##### Interaction & keys #####

# Enable xterm-style keys (e.g. Shift+Arrow)
setw -g xterm-keys on

# Send terminal focus in/out events
set -s focus-events on

# Use vi keys in copy mode
setw -g mode-keys vi

# Esc delay — pin the modern default (10ms) explicitly
set -s escape-time 10

# Time window for repeatable key bindings (ms)
set -g repeat-time 500


##### Status & notifications #####

# Refresh status line every 5s
set -g status-interval 5

# Duration of messages (ms)
set -g display-time 1000

# Duration of pane number overlay (ms)
set -g display-panes-time 1500

# Activity monitoring: log but no visual bell
set -g monitor-activity on
set -g visual-activity off
set -g bell-action none


##### Key bindings #####

# Split panes and open the same path
bind | split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"

# Open new window with the same path
bind c new-window -c "#{pane_current_path}"

# Toggle full screen mode
bind f resize-pane -Z

# Convert pane into a window
bind F break-pane \; display-message "Pane moved to a separate window"

# Toggle synchronize-panes
bind S setw synchronize-panes \; display-message "Toggled synchronize-panes"

# Copy mode
bind v copy-mode

# Prevent mouse drag in normal mode from entering copy mode
unbind -T root MouseDrag1Pane

# Announce tmux to the outer terminal (e.g. wezterm) via OSC user-var so
# Alt-hjkl gets forwarded to us through SSH/et. Symmetric to smart-splits.nvim's
# IS_NVIM signal. Requires `allow-passthrough on` (set above).
#
# Important: write directly to #{client_tty} (the wezterm-facing tty);
# `run-shell` captures stdout to tmux's message area, so without the redirect
# the OSC never leaves tmux. base64("true") = "dHJ1ZQ==" hard-coded for clarity.
# No client-detached hook: by the time it fires, the client tty is gone, and
# the staleness ("IS_TMUX=true sticks after detach") is acceptable per workflow.
set-hook -g client-attached 'run-shell -b "printf \"\\033]1337;SetUserVar=IS_TMUX=dHJ1ZQ==\\007\" > #{client_tty}"'

# Use Alt-hjkl to switch panes (compatible with smart-splits.nvim)
is_vim="ps -o state= -o comm= -t '#{pane_tty}' | grep -iqE '^[^TXZ ]+ +(\\S+\\/)?g?(view|l?n?vim?x?|fzf)(diff)?$'"
bind -n M-h if-shell "$is_vim" "send-keys M-h" "select-pane -L"
bind -n M-j if-shell "$is_vim" "send-keys M-j" "select-pane -D"
bind -n M-k if-shell "$is_vim" "send-keys M-k" "select-pane -U"
bind -n M-l if-shell "$is_vim" "send-keys M-l" "select-pane -R"

# Alt-Shift-HJKL to resize panes (forwards to nvim's smart-splits when active)
bind -n M-H if-shell "$is_vim" "send-keys M-H" "resize-pane -L 3"
bind -n M-J if-shell "$is_vim" "send-keys M-J" "resize-pane -D 3"
bind -n M-K if-shell "$is_vim" "send-keys M-K" "resize-pane -U 3"
bind -n M-L if-shell "$is_vim" "send-keys M-L" "resize-pane -R 3"

# Alt-i/o to switch windows (no wrap-around)
bind -n M-i if -F '#{?window_start_flag,,1}' 'previous-window'
bind -n M-o if -F '#{?window_end_flag,,1}'   'next-window'

# Vi-like selection in copy mode
bind -T copy-mode-vi v send -X begin-selection
bind -T copy-mode-vi V send -X select-line
bind -T copy-mode-vi M-v send -X rectangle-toggle
bind -T copy-mode-vi Home send -X start-of-line
bind -T copy-mode-vi End  send -X end-of-line

# Do not cancel copy mode after copy
bind -T copy-mode-vi y send -X copy-selection
bind -T copy-mode-vi MouseDragEnd1Pane send -X copy-selection

# Copy last command output — Alt-Y, the same key as the zsh widget of
# the same name (zsh/config.d/copy_last_output.zsh). In a vim/nvim pane
# forward Alt-Y to the app instead, like the M-hjkl bindings above.
bind -n M-Y if-shell "$is_vim" "send-keys M-Y" {
    if-shell -b "tmux capture-pane -p -J | tail -n 2 | grep -q '❯'" {
        copy-mode
        send -X search-backward '❯'
        send -X search-backward '❯'
        send -X begin-selection
        send -X search-forward '❯'
        send -X cursor-up
        send -X cursor-up
        send -X end-of-line
        send -X copy-pipe-and-cancel "tmux load-buffer -w -b lastcmd -"
        display-message 'Copied last command output'
    } {
        copy-mode
        send -X search-backward '❯'
        send -X begin-selection
        send -X bottom-line
        send -X end-of-line
        send -X copy-pipe-and-cancel "tmux load-buffer -w -b lastcmd -"
        display-message 'Copied last command output'
    }
}

# Quickly jump between shell prompts
bind P copy-mode \; send -X search-backward "❯"
bind N copy-mode \; send -X search-forward "❯"
bind -T copy-mode-vi P send -X search-backward "❯"
bind -T copy-mode-vi N send -X search-forward  "❯"

##### Theme #####

set -g @catppuccin_flavor 'mocha'
set -g @catppuccin_window_text "#W"
set -g @catppuccin_window_current_text "#W"
set -g @catppuccin_window_current_number "#I#{?window_zoomed_flag, ,}"
set -g @catppuccin_window_number_position "right"

# Default icon may break tmux statusline in older Windows Terminal versions.
# Uncomment to fix or better update Windows Terminal.
#set -g @catppuccin_host_icon " "

# Make status line pretty
set -g status-right-length 100
set -g status-left-length 100
set -g status-left "#{tmux_mode_indicator} "
set -g status-right "#{E:@catppuccin_status_user}"
set -ag status-right "#{E:@catppuccin_status_host}"
set -ag status-right "#{E:@catppuccin_status_session}"


##### Mode Indicator #####

set -g @mode_indicator_prefix_prompt " WAIT "
set -g @mode_indicator_copy_prompt " COPY "
set -g @mode_indicator_sync_prompt " SYNC "
set -g @mode_indicator_empty_prompt " TMUX "

# Upstream publishes no tags (dormant since 2021), so tpm can't pin it;
# the nixpkgs build rides flake.lock instead, loaded like tmux-fingers.
# Must run after status-left is set (it substitutes the
# #{tmux_mode_indicator} placeholder) and after the prompts above.
run-shell ~/.nix-profile/share/tmux-plugins/mode-indicator/mode_indicator.tmux


##### Extrakto #####

set -g @extrakto_clip_tool_run "tmux_osc52"
set -g @extrakto_filter_order "path word line all"
set -g @extrakto_grab_area "recent"

# Tagless upstream, same story as mode-indicator: pinned via flake.lock,
# loaded from the nix profile instead of tpm.
run-shell ~/.nix-profile/share/tmux-plugins/extrakto/extrakto.tmux


##### Fingers #####

set -g @fingers-key G
bind -n M-g run -b "#{@fingers-cli} start #{pane_id}"
# Jump-mode shortcut moved off M-j (which is pane-down) to M-y. Mnemonic: "yank".
bind -n M-y run -b "#{@fingers-cli} start #{pane_id} --mode jump"

# Load tmux-fingers from the nix-server profile (nixpkgs ships a pre-built
# binary + wrapper — no Crystal toolchain or RPATH gymnastics needed).
run-shell ~/.nix-profile/share/tmux-plugins/tmux-fingers/tmux-fingers.tmux


##### Resurrect & Continuum #####

# Continuum still auto-SAVES every 10 minutes (so a manual restore has
# something to restore). Auto-RESTORE is disabled — restore by hand
# with `prefix + C-r` (tmux-resurrect's default binding). Auto-restore
# fires during the initial client attach, and the resulting spawn
# flurry can interact badly with OSC user-var emissions reaching
# wezterm (see Alt-hjkl forwarding chain).
set -g @resurrect-capture-pane-contents 'on'
set -g @continuum-restore 'off'
set -g @continuum-save-interval '10'


##### Plugins #####

# All tpm plugins are pinned to a tag. Plugins whose upstream has no
# tags (extrakto, mode-indicator) load from the nix profile above and
# pin via flake.lock instead, as does fingers (nixpkgs pre-builds it).
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'catppuccin/tmux#v2.1.3'
set -g @plugin 'tmux-plugins/tmux-resurrect#v4.0.0'
set -g @plugin 'tmux-plugins/tmux-continuum#v3.1.0'
run '~/.tmux/plugins/tpm/tpm'

# Override Catppuccin style for selected text
set -g mode-style "fg=#cdd6f4,bg=#585b70"

# Dim inactive panes
set -g window-style 'fg=#b7b9c5,bg=#24243a'
set -g window-active-style 'fg=#eeeeee,bg=#1e1e2e'
{{- end }}
