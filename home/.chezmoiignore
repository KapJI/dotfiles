.config/sublime_text
{{ end }}

{{ if not (or (has .osid (list "darwin" "windows")) (eq .chezmoi.hostname "homeserver" )) }}
# Non-primary SSH pubkeys: only synced on macOS, Windows, or homeserver.
# Re-include the directory itself so the negation for github_key.pub takes
# effect (chezmoi won't surface a file inside an ignored directory).
.ssh/pubkeys/**
!.ssh/pubkeys
!.ssh/pubkeys/github_key.pub
{{ if .is_desktop }}
# Linux desktop also needs sudo_key.pub for pam_ssh_agent_auth (see
# linux/after_50-configure-pam-auth.sh).
!.ssh/pubkeys/sudo_key.pub
{{ end }}
{{ end }}
