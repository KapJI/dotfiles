#!/bin/sh
#
# Recurse from a directory (default: .) and print any .a static
# libraries that define the requested symbol.
if [ -z "${1:-}" ]; then
    echo "usage: find-symbol <symbol> [dir]" >&2
    exit 1
fi
sym=$1
p=${2:-.}
echo "Search for: $sym in $p"
find "$p" -name '*.a' | while IFS= read -r i; do
    if nm --defined-only "$i" 2>/dev/null | grep -- "$sym"; then
        echo "$i"
    fi
done
