#!/bin/bash
# scp-speed
#
# Usage:
#   scp-speed user@hostname [test file size in MBs]
#
#############################################################

if [ -z "${1:-}" ]; then
    echo "usage: scp-speed user@hostname [test file size in MBs]" >&2
    exit 1
fi

ssh_server=$1
test_file=".scp-test-file"
test_size=${2:-10}

# generate a file of all zeros
echo "Generating $test_size MB test file..."
dd if=/dev/zero of="$test_file" bs=$((test_size * 1024 * 1024)) count=1

cleanup() {
    rm -f "$test_file"
}
trap cleanup EXIT

# upload test
echo "Testing upload to $ssh_server..."
up_bytes=$(scp -v "$test_file" "$ssh_server:$test_file" 2>&1 |
    grep "Bytes per second" |
    sed "s/^[^0-9]*\([0-9.]*\)[^0-9]*\([0-9.]*\).*$/\1/g")
if [ -z "$up_bytes" ]; then
    echo "Upload failed (no transfer stats from scp) — aborting." >&2
    exit 1
fi
up_speed=$(echo "$up_bytes/1000000" | bc)

# download test
echo "Testing download from $ssh_server..."
down_bytes=$(scp -v "$ssh_server:$test_file" "$test_file" 2>&1 |
    grep "Bytes per second" |
    sed "s/^[^0-9]*\([0-9.]*\)[^0-9]*\([0-9.]*\).*$/\2/g")
if [ -z "$down_bytes" ]; then
    echo "Download failed (no transfer stats from scp) — aborting." >&2
    exit 1
fi
down_speed=$(echo "$down_bytes/1000000" | bc)

# clean up
echo "Removing test file on $ssh_server..."
ssh "$ssh_server" "rm $test_file"

# print result
echo ""
echo "Upload speed:   $up_speed MB/s"
echo "Download speed: $down_speed MB/s"
